# Sample environment file for the vault-secrets-manager Docker Compose stack.
# Copy to `.env` in the repo root and adjust values as needed.
#
#   cp .env.example .env
#
# NONE of the values below are secrets. Real tokens/keys produced by
# `vault operator init` are written to .vault/init.json and MUST NOT be
# committed (see .gitignore).

# --- Vault ---------------------------------------------------------------
# Address that clients use to reach Vault. Scripts default to this if unset.
VAULT_ADDR=http://127.0.0.1:8200

# Log level: trace | debug | info | warn | error
VAULT_LOG_LEVEL=info

# Number of key shares + recovery threshold when calling `operator init`.
# The defaults (5 shares / 3 threshold) match HashiCorp's recommendation.
VAULT_INIT_KEY_SHARES=5
VAULT_INIT_KEY_THRESHOLD=3

# --- Consul --------------------------------------------------------------
CONSUL_HTTP_ADDR=http://127.0.0.1:8500

# --- Scripts / bootstrap -------------------------------------------------
# Directory (relative to repo root) where init-vault.sh will persist the
# generated unseal keys and initial root token. This path is in .gitignore.
VAULT_INIT_OUTPUT_DIR=.vault

# Path on the host / container to emit the audit log to.
VAULT_AUDIT_LOG_PATH=/vault/logs/audit.log

# Secret seeding (used by scripts/seed-secrets.sh). These are EXAMPLE values
# and intentionally harmless; replace them with anything you like for local
# testing. Do not reuse real credentials.
SEED_APP_DB_USER=app
SEED_APP_DB_PASSWORD=change-me-local-only
SEED_API_KEY=example-api-key-change-me
